store(&VERSION) '10.0'
store(&COPYRIGHT) 'Copyright © 网络赣语研究会©'
store(&KEYBOARDVERSION) '11.9.7'
store(&TARGETS) 'any'
store(&NAME) 'gekuado'
store(&BITMAP) 'gekuado.ico'
store(&VISUALKEYBOARD) 'gekuado.kvks'
store(&LAYOUTFILE) 'gekuado.keyman-touch-layout'

begin Unicode > use(main)

group(main) using keys

store(vowels) 'aiueoüAIUEOÜ'
store(vowels_tone1) 'āīūēōǖĀĪŪĒŌǕ'
store(vowels_tone2) 'áíúéóǘÁÍÚÉÓǗ'
store(vowels_tone3) 'ǎǐǔěǒǚǍǏǓĚǑǙ'
store(vowels_tone4) 'àìùèòǜÀÌÙÈÒǛ'
store(vowels_tone5) 'ąįũęøůÀÌÙÈÒǛ'
store(vowels_tone6) 'âîûêôųÀÌÙÈÒǛ'

+ 'w' > 'ü'
+ 'W' > 'Ü'

'ü' + 'w' > 'w'
'Ü' + 'W' > 'W'
'Ü' + 'W' > 'W'

any(vowels) + "j" > index(vowels_tone1, 1)
any(vowels) "n" + "j" > index(vowels_tone1, 1) "n"
any(vowels) "N" + "j" > index(vowels_tone1, 1) "N"
any(vowels) "ng" + "j" > index(vowels_tone1, 1) "ng"
any(vowels) "NG" + "j" > index(vowels_tone1, 1) "NG"
any(vowels) "j" + "j" > index(vowels_tone1, 1) "j"
