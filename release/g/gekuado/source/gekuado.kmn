any(vowels) "NJ" + "j" > index(vowels_tone1, 1) "NJ"
any(vowels) "ngj" + "j" > index(vowels_tone1, 1) "ngj"
any(vowels) "NGJ" + "j" > index(vowels_tone1, 1) "NGJ"

